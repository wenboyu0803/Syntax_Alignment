##大模型的答案
jisuanFUN <- function(x, center = TRUE, spread = TRUE) {
  x <- x[!is.na(x)]
  res <- list()
  if (center)
    res$center <- c(mean = mean(x), median = median(x))
  if (spread)
    res$spread <- c(
      sd = sd(x),
      mad = mad(x),
      var = var(x),
      range = max(x) - min(x)
    )
  return(res)
}

