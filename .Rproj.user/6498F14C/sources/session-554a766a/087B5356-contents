```{r 杨思恩答案}
calculate_stats <- function(x, type = "central") {
  if(!is.numeric(x)) {
    stop("输入必须为数值向量")
  }
  if(type == "central") {
    mean_val <- mean(x, na.rm = TRUE)
    sd_val <- sd(x, na.rm = TRUE)
    result <- paste(round(mean_val, 2), round(sd_val, 2), sep = "_")
    cat("集中趋势（均值_标准差）:", result, "\n")
    
  } else if(type == "dispersion") {
    median_val <- median(x, na.rm = TRUE)
    mad_val <- mad(x, na.rm = TRUE)  
    result <- paste(round(median_val, 2), round(mad_val, 2), sep = "_")
    cat("离散趋势（中位数_绝对中位差）:", result, "\n")
    
  } else {
    stop("type参数必须是'central'或'dispersion'")
  }
  return(result)
}

