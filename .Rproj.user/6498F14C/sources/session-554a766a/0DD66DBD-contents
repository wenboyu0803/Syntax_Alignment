```{r null distribution}
DIFF_null = numeric(length = 10000)
set.seed(1234)
for(i in 1:10000){
  Aidx = sample(1:11, 5)
  A_permutation = c(A, B)[Aidx]
  B_permutation = c(A, B)[-Aidx] #体现了无放回
  DIFF_null[i] = mean(A_permutation) - mean(B_permutation)
}
p = min(mean(DIFF_null > DIFF), mean(DIFF_null < DIFF))*2
