cor.boot <- function(df, per.num) {
  OP = numeric(length = per.num)
  PQ = numeric(length = per.num)
  OQ = numeric(length = per.num)
  for (i in 1:per.num) {
    idx <- sample(1:nrow(df), nrow(df), replace = TRUE)
    boot.df <- df[idx, ]
    result <- bruceR::Corr(boot.df)
    OP[i] <- result$corr$r[1, 2]
    PQ[i] <- result$corr$r[1, 3]
    OQ[i] <- result$corr$r[2, 3]
  }
  OP.drop <- OP[!is.na(OP)]
  PQ.drop <- PQ[!is.na(PQ)]
  OQ.drop <- OQ[!is.na(OQ)]
  return(list(OP = OP.drop, PQ = PQ.drop, OQ = OQ.drop))
}

