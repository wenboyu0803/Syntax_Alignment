5. 实例2
```{r 手动计算}
set.seed(1128)
a <- rnorm(6, 5, 1) |> round(3)
b <- rnorm(6, 7, 1) |> round(3)
df.ab <- data.frame(x = factor(rep(c("a", "b"), each = 6)), y = c(a, b))
real.diff.ab <- mean(a) - mean(b)

per.fun <- function(DF, n_per) {
  results <- numeric(n_per)
  for (i in 1:n_per) {
    dif.null <- DF |>
      dplyr::mutate(y_per = sample(y, replace = FALSE)) |>
      group_by(x) |>
      summarise(mean_per = mean(y_per)) |>
      ungroup() |>
      summarise(diff = mean_per[1] - mean_per[2]) |>
      pull(diff)
    results[i] <- dif.null
  }
  extreme_cases <- sum(abs(results) >= abs(real.diff.ab))
  p_value <- (extreme_cases + 1) / (n_per + 1) #体现p值的含义，当前数据或更极端数据
  return(list(p_value = p_value,
              Real_diff = real.diff.ab,
              Permutation_Results = results
              )
         )
}

per.result <- per.fun(df.ab, 1000)
per.result$p_value
cat("在零分布中（ab两组没有差异），得到比真实差异",
    real.diff.ab,
    "更极端的可能性为",
    per.result$p_value,
    "\n")
```


