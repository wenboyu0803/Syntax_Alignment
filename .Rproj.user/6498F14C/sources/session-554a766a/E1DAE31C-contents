```{r 宋婷立数据异常值处理+分组操作2}
fangfa <- c("sd", "boxplot", "percentiles") #设置一个循环的范围
index = list()    #建立一个空的list存放极端数据的索引
hb.list <- list()  #创建一个空的list存放删除极端数据的数据
for (i in fangfa){
  id <- hebing$RT %>% univ_outliers(method = i)
  index[[i]] <- id[[2]]
  hb <- hebing[-index[[i]],]%>%
    group_by(Group)%>%             #分组
    summarise(mean.rt = mean(RT))  #计算均值
  hb.list[[i]] <- hb               #存储
}
hb <- cbind(hebing.A, hb.list[[1]][2], hb.list[[2]][2], hb.list[[3]][2])
colnames(hb) <- c("group", "A", "B", "C", "D")
hb <- hb |> mutate(across(2:5, ~ round(.x, 3)))
```


