```{r 声调的影响}
# 加载必要的包
library(tidyverse)
library(broom)

# 1. 读取Excel数据
data <- readxl::read_excel("差值三个指标.xlsx")

# 2. 重命名列名
data <- data %>%
  rename(
    subject = "组别",
    tone = "声调",
    f0_mean = "基频平均值（组内-组间）",
    amp_mean = "振幅平均值（组内-组间）",
    speech_rate = "语速（组内-组间）"
  )

# 3. 定义要分析的变量列表
variables <- c("f0_mean", "amp_mean", "speech_rate")

# 4. 置换检验函数
permutation_test <- function(data, variable, n_permutations = 10000) {
  cat(paste("\n=== 置换检验：", variable, "===\n"))
  
  # 计算原始F值
  formula <- as.formula(paste(variable, "~ tone"))
  original_anova <- aov(formula, data = data)
  original_f <- summary(original_anova)[[1]]$"F value"[1]
  
  cat(paste("原始F值:", round(original_f, 4), "\n"))
  
  # 进行置换检验
  perm_f_values <- numeric(n_permutations)
  
  for (i in 1:n_permutations) {
    # 随机置换因变量值（保持组结构）
    perm_data <- data
    perm_data[[variable]] <- sample(data[[variable]])
    
    # 计算置换后的F值
    perm_anova <- aov(formula, data = perm_data)
    perm_f_values[i] <- summary(perm_anova)[[1]]$"F value"[1]
  }
  
  # 计算p值：置换F值大于等于原始F值的比例
  p_value <- sum(perm_f_values >= original_f) / n_permutations
  
  cat(paste("置换检验p值:", round(p_value, 5), "\n"))
  cat(paste("置换次数:", n_permutations, "\n"))
  
  # 返回结果
  return(list(
    variable = variable,
    original_f = original_f,
    p_value = p_value,
    perm_f_values = perm_f_values,
    n_permutations = n_permutations
  ))
}

# 5. 对每个变量进行置换检验
results <- list()

for (var in variables) {
  results[[var]] <- permutation_test(data, var, n_permutations = 10000)
}

# 6. 显示所有结果
cat("\n=== 置换检验结果汇总 ===\n")
for (var in variables) {
  result <- results[[var]]
  significance <- ifelse(result$p_value < 0.05, "显著", "不显著")
  
  cat(paste("\n变量:", var, "\n"))
  cat(paste("原始F值:", round(result$original_f, 4), "\n"))
  cat(paste("置换p值:", round(result$p_value, 5), "\n"))
  cat(paste("显著性:", significance, "\n"))
}
