```{r fig2 不控制声调条件下三个声学指标的组间差异和组内差异比较}
data <- readxl::read_excel("总数据.xlsx")
data_bkz <- data |> dplyr::filter(声调 == "自然声调") |>
  dplyr::mutate(across(where(is.numeric), ~ round(.x, 2))) |>
  pivot_longer(cols = "基频平均值" : "语速", names_to = "指标", values_to = "Value") |>
  dplyr::mutate(group_name = factor(group_name),
                差异类型 = factor(差异类型),
                指标 = factor(指标))|>
  as.data.frame()

figbkz <- ggplot(data_bkz, aes(x = 差异类型, y = Value))+
  geom_half_violin(data = ~ subset(.x, 差异类型 == "组内差异"),
                   aes(color = 差异类型), size = 1, side = "l", alpha = 0.8)+
  geom_half_violin(data = ~ subset(.x, 差异类型 == "组间差异"),
                   aes(color = 差异类型), size = 1, side = "r", alpha = 0.8)+
  geom_boxplot(aes(color = 差异类型), width = 0.3, size = 1)+
  geom_line(aes(group = group_name), color = "grey70", linewidth = 0.80)+
  geom_jitter(aes(color = 差异类型),      # 只用 color
              alpha = 0.6, size = 3,      # 调整透明度
              width = 0.02)+              # 不用 pch，默认就是实心点
  labs(y = "声学参数的差异", x = NULL)+
  facet_wrap(~ 指标, nrow = 1, scales = "free_y", 
             labeller = labeller(指标 = c("基频平均值" = "基频",  
                                          "振幅平均值" = "强度", 
                                          "语速" = "语速"))) +
  theme_test()+
  scale_color_manual(values = c("#D22630", "#3A7D34"))+  # 只保留 color scale
  theme(axis.text.x = element_text(size = 11, color = "black"),
        axis.text.y = element_text(size = 10, color = "black"),
        axis.title.y = element_text(size = 11, color = "black"),
        axis.ticks.y = element_blank(),
        strip.text = element_text(size = 11, color = "black"),
        legend.position = "none", 
        panel.grid.major = element_line(size = 0.2, color = "#e5e5e5"))
figbkz
ggsave("./figbkz.svg", plot = figbkz, width = 6.5, height = 3.5)
ggsave("./figbkz.png", plot = figbkz, width = 6.5, height = 3.5)
