```{r 基频、强度和语速是否存在韵律协同}
# 加载必要的包
library(readxl)
library(dplyr)

# 读取数据
data <- read_excel("总数据.xlsx")

# 获取唯一的声调类型
tones <- unique(data$声调)
# 需要检验的指标
metrics <- c("基频平均值", "振幅平均值", "语速")

# 设置随机种子以确保结果可重复
set.seed(1234)

# 创建存储结果的数据框
results <- data.frame(
  声调 = character(),
  指标 = character(),
  组内均值 = numeric(),
  组间均值 = numeric(),
  差异值 = numeric(),
  p值 = numeric(),
  stringsAsFactors = FALSE
)

# 外层循环：遍历每个声调
for (tone in tones) {
  # 中层循环：遍历每个指标
  for (metric in metrics) {
    
    # 提取当前声调当前指标的组内差异数据
    A <- data %>%
      filter(声调 == tone, 差异类型 == "组内差异") %>%
      pull(metric)
    
    # 提取当前声调当前指标的组间差异数据
    B <- data %>%
      filter(声调 == tone, 差异类型 == "组间差异") %>%
      pull(metric)
    
    # 直接使用您的代码逻辑，不检查数据长度
    # 计算实际观测到的差异
    DIFF <- mean(A) - mean(B)
    
    # 置换检验（完全使用您的代码逻辑）
    DIFF_null <- numeric(length = 10000)
    
    # 合并两组数据
    combined_data <- c(A, B)
    
    for (i in 1:10000) {
      # 直接使用30和15，不检查数据长度
      Aidx <- sample(1:30, 15)  # 您的原样代码
      A_permutation <- combined_data[Aidx]
      B_permutation <- combined_data[-Aidx]  # 体现了无放回
      DIFF_null[i] <- mean(A_permutation) - mean(B_permutation)
    }
    
    # 计算双尾p值
    #p <- min(mean(DIFF_null > DIFF), mean(DIFF_null < DIFF)) * 2
    p <- mean(abs(DIFF_null) >= abs(DIFF))
    
    # 存储结果
    results <- rbind(results, data.frame(
      声调 = tone,
      指标 = metric,
      组内均值 = mean(A),
      组间均值 = mean(B),
      差异值 = DIFF,
      p值 = p,
      stringsAsFactors = FALSE
    ))
    
    # 输出当前检验结果
    cat("\n====================\n")
    cat("声调:", tone, "| 指标:", metric, "\n")
    cat("组内样本数:", length(A), "| 组间样本数:", length(B), "\n")
    cat("组内均值:", mean(A), "| 组间均值:", mean(B), "\n")
    cat("差异值:", DIFF, "\n")
    cat("p值:", p, "\n")
    if (p < 0.05) {
      cat("结果: 显著 (p < 0.05)\n")
    } else {
      cat("结果: 不显著\n")
    }
  }
}

# 输出所有结果
cat("\n\n==================== 汇总结果 ====================\n")
print(results)

# 添加显著性标记
results$显著性 <- ifelse(results$p值 < 0.001, "***",
                       ifelse(results$p值 < 0.01, "**",
                              ifelse(results$p值 < 0.05, "*", "ns")))

# 按声调排序
results <- results[order(results$声调, results$指标), ]

# 输出格式化结果
cat("\n==================== 格式化结果 ====================\n")
for (i in 1:nrow(results)) {
  cat(sprintf("%s - %s: 差异=%.4f, p=%.4f %s\n",
              results$声调[i], 
              results$指标[i],
              results$差异值[i],
              results$p值[i],
              results$显著性[i]))
}

# 保存结果到CSV文件
write.csv(results, "置换检验结果.csv", row.names = FALSE, fileEncoding = "UTF-8")
cat("\n结果已保存到: 置换检验结果.csv\n")
