```{r 等价检验 自然声调}
library(TOSTER)
library(car)
library(readxl)

# 读取数据
data <- read_excel("总数据.xlsx", sheet = 1)

# 设置效应量
d_value <- 1.2
tone <- "自然声调"  # 直接定义

cat("\n=== 声调:", tone, "===\n")

# 提取数据
tone_data <- data[data$声调 == tone, ]
within_data <- unlist(tone_data[tone_data$差异类型 == "组内差异", "基频平均值"])
between_data <- unlist(tone_data[tone_data$差异类型 == "组间差异", "基频平均值"])
# 创建数据框
  ab <- data.frame(
    value = c(within_data, between_data),
    condition = c(rep("组内", length(within_data)), rep("组间", length(between_data)))
  )
  
  # 计算合并标准差和边界
  n1 <- length(within_data)
  n2 <- length(between_data)
  pooled_sd <- sqrt(((n1-1)*var(within_data) + (n2-1)*var(between_data)) / (n1 + n2 - 2))
  eq_boundary_raw <- d_value * pooled_sd
  
  # 添加分析设置输出
  cat("=== 分析设置 ===\n")
  cat("合并标准差 =", round(pooled_sd, 2), "\n")
  cat("效应量d =", d_value, "\n")
  cat("对应的原始单位边界 = ±", round(eq_boundary_raw, 2), "\n")
  cat("实际观察到的差异 =", round(mean(between_data) - mean(within_data), 2), "\n\n")
  
  # 方差齐性检验
  levene_result <- car::leveneTest(value ~ condition, data = ab)
  var_equal_flag <- ifelse(levene_result$`Pr(>F)`[1] > 0.05, TRUE, FALSE)
  
  # 进行等价检验
  TOS.ab <- dataTOSTtwo(ab, deps = "value", group = "condition", 
                        var_equal = var_equal_flag,
                        low_eqbound = -eq_boundary_raw, 
                        high_eqbound = eq_boundary_raw,
                        desc = FALSE, plots = FALSE)
  
  cat("=== TOST等价检验结果 ===\n")
  print(TOS.ab$tost) 
```



```{r 等价检验}
library(TOSTER)
library(car)
library(readxl)

data <- read_excel("差值三个指标.xlsx", sheet = 1)

tones <- c("全阴平调", "全阳平调", "全去声调", "自然声调")
tone_pairs <- combn(tones, 2, simplify = FALSE)

# ========== 基频(Hz) ==========
eq_boundary_f0 <- 1.0

freq_data_f0 <- data.frame(
  value = data$`基频平均值（组内-组间）`,
  group = factor(data$`声调`, levels = tones)
)

cat("=== 基频分析 ===\n")
cat("等价边界 = ±", eq_boundary_f0, "Hz\n")

for (pair in tone_pairs) {
  tone1 <- pair[1]
  tone2 <- pair[2]
  
  cat("\n---", tone1, "vs", tone2, "---\n")
  
  data1 <- freq_data_f0$value[freq_data_f0$group == tone1]
  data2 <- freq_data_f0$value[freq_data_f0$group == tone2]
  
  cat("样本量:", length(data1), "/", length(data2), "\n")
  cat("均值差 =", round(mean(data1) - mean(data2), 2), "Hz\n")
  
  ab <- data.frame(value = c(data1, data2),
                   condition = c(rep(tone1, length(data1)), rep(tone2, length(data2))))
  
  lev <- leveneTest(value ~ condition, data = ab)
  
  TOS <- dataTOSTtwo(ab, deps = "value", group = "condition",
                     var_equal = lev$`Pr(>F)`[1] > 0.05,
                     low_eqbound = -eq_boundary_f0,
                     high_eqbound = eq_boundary_f0,
                     desc = FALSE, plots = FALSE)
  
  print(TOS$tost)
}

# ========== 音强(dB) ==========
eq_boundary_amp <- 2.5

freq_data_amp <- data.frame(
  value = data$`振幅平均值（组内-组间）`,
  group = factor(data$`声调`, levels = tones)
)

cat("\n\n=== 音强分析 ===\n")
cat("等价边界 = ±", eq_boundary_amp, "dB\n")

for (pair in tone_pairs) {
  tone1 <- pair[1]
  tone2 <- pair[2]
  
  cat("\n---", tone1, "vs", tone2, "---\n")
  
  data1 <- freq_data_amp$value[freq_data_amp$group == tone1]
  data2 <- freq_data_amp$value[freq_data_amp$group == tone2]
  
  cat("样本量:", length(data1), "/", length(data2), "\n")
  cat("均值差 =", round(mean(data1) - mean(data2), 2), "dB\n")
  
  ab <- data.frame(value = c(data1, data2),
                   condition = c(rep(tone1, length(data1)), rep(tone2, length(data2))))
  
  lev <- leveneTest(value ~ condition, data = ab)
  
  TOS <- dataTOSTtwo(ab, deps = "value", group = "condition",
                     var_equal = lev$`Pr(>F)`[1] > 0.05,
                     low_eqbound = -eq_boundary_amp,
                     high_eqbound = eq_boundary_amp,
                     desc = FALSE, plots = FALSE)
  
  print(TOS$tost)
}

# ========== 语速 ==========
eq_boundary_sr <- 0.3

freq_data_sr <- data.frame(
  value = data$`语速（组内-组间）`,
  group = factor(data$`声调`, levels = tones)
)

cat("\n\n=== 语速分析 ===\n")
cat("等价边界 = ±", eq_boundary_sr, "\n")

for (pair in tone_pairs) {
  tone1 <- pair[1]
