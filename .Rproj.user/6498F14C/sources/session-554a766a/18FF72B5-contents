```{r}
univ_outliers = function(x,
                         method = "boxplot",
                         k = NULL,
                         coef = NULL,
                         lp = NULL,
                         up = NULL) {
  switch(
    method,
    "sd" = {
      if (is.null(k))
        k = 3 #默认是三个标准差
      mu = mean(x, na.rm = TRUE)
      sd = sd(x, na.rm = TRUE)
      LL = mu - k * sd
      UL = mu + k * sd
    },
    "boxplot" = {
      if (is.null(coef))
        coef = 1.5 #默认是1.5个全距
      Q1 = quantile(x, 0.25, na.rm = TRUE)
      Q3 = quantile(x, 0.75, na.rm = TRUE)
      iqr = Q3 - Q1
      LL = Q1 - coef * iqr
      UL = Q3 + coef * iqr
    },
    "percentiles" = {
      if (is.null(lp))
        lp = 0.025
      if (is.null(up))
        up = 0.975 #默认是0.05以外
      LL = quantile(x, lp)
      UL = quantile(x, up)
    }
  )
  
  idx = which(x < LL | x > UL)
  n = length(idx)
  list(outliers = x[idx],
       outlier_idx = idx,
       outlier_num = n)
}
```

