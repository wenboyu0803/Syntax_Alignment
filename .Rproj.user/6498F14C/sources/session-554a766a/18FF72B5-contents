```{r}
plot_piece <- function(mz, nm, k = 2.5) {
  x   <- mz[["RT"]]
  mu  <- mean(x, na.rm = TRUE)
  sd  <- sd(x, na.rm = TRUE)
  LL  <- mu - k * sd
  UL  <- mu + k * sd
  idx <- which(x < LL | x > UL)
  lab_df <- tibble(RT = x[idx], id = idx)

  ggplot(mz, aes(RT)) +
    geom_density(fill = "#5D92B1", colour = "#1B3B6F",
                 alpha = .7, size = 1.1) +
    geom_vline(xintercept = c(LL, UL), linetype = "dashed",
               colour = "#B44C4C", size = 1) +
    geom_point(data = lab_df, aes(x = RT, y = 0),
               shape = 1, colour = "#E8A128",
               size = 1.5, stroke = 0.6) +
    geom_text(data = lab_df, aes(x = RT, y = 0, label = id),
              colour = "#E8A128", size = 3.5,
              vjust = -1.5, fontface = "bold") +
    theme_apa() +
    labs(x = "RT", y = "Density") +
    theme(plot.title = element_blank())
}

plot_list <- lapply(names(pieces), function(nm)
