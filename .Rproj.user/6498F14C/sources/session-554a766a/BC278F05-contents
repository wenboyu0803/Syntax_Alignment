```{r 循环读取数据方法1}
files = fs::dir_ls("./test/data")
df.list <- list()
datanames <- c("d1", "d2", "d3")
m = 1
for (n in files){
  df.list[[datanames[m]]] <- import(n)
  m = m + 1
}
d1 <- df.list$d1
d2 <- df.list$d2
d3 <- df.list$d3
```

```{r 循环读取数据方法2}
file = fs::dir_ls("./test/data")
m = 1
for (n in file){
  x <- import(n)
  y <- paste0("df", m)
  assign(y, x)
  m = m + 1
}
```


```{r 数据1}
dt11 <- dt1 %>% drop_na()
is.na.data.frame(dt1) #查看是否有NA
unique(is.na.data.frame(dt11)) #删除掉重复的值，看看清理的对不对
dt12 <- dt11 %>%
  dplyr::filter(if_all(where(is.numeric), ~ .x == 0 | .x == 1))
de_num <- nrow(dt12) - nrow(dt1) #查看删除掉NA和错误记录数据的数量
de_pro <- de_num / nrow(dt1) #查看删除掉数据占据比例（加分项）
cat("因为缺失值删除的数据占比:", abs(round(de_pro, 3)), "\n")

dt13 <- dt12 %>%
  dplyr::select(starts_with(c("age", "sex", "fennu", "beishang"))) %>% #筛选有用的列
  dplyr::mutate(
    fennu.acc = (fennu1 + fennu2 + fennu3 + fennu4) / 4,
    #计算正确率
    beishang.acc = (beishang1 + beishang2 + beishang3 + beishang4) / 4) %>%
  group_by(sex) %>%
  summarise(mean.fennu = mean(fennu.acc),
            mean.beishang = mean(beishang.acc))
```

```{r 数据2}
dt21 <- dt2 %>% drop_na()
#is.na.data.frame(dt2) #查看是否有NA
unique(is.na.data.frame(dt21)) #删除掉重复的值，看看清理的对不对

dt22 <- dt21 %>%  
  filter(if_all(3:18, ~ .x == 0 | .x == 1))%>% #筛选出来等于0或者等于1的
  mutate(beishang3 = as.numeric(beishang3),  #将变量转换成数值型
         beishang4 = as.numeric(beishang4))
de_num <- nrow(dt22) - nrow(dt21)
de_pro <- de_num/nrow(dt21)
cat("因为缺失值删除的数据占比:", abs(round(de_pro, 3)), "\n")

dt23 <- dt22 %>%
  dplyr::mutate(mean = rowMeans(.[3:18]), #计算特定列的正确率
                id = 1:nrow(.))%>% 
  dplyr::select(id, sex, age, everything())%>%   #排序
  group_by(age) %>%
  summarise(Mean = mean(mean))


#殷和吴的写法
dt231 <- dt22 %>%
  dplyr::mutate(mean.new = rowMeans(select(., starts_with("gaoxing")))) # 思考为什么一定要写·
```

```{r 数据3}
dt31 <- dt3 %>% drop_na()
#is.na.data.frame(dt1) #查看是否有NA
