```{r 通过添加if函数来处理向量}
fenshu <- c(17, 86, 90)
dengjifun <- function(x) {
  if (length(x) == 1)
    #先进行判断，是不是只有一个元素
  {
    if (x > 90) {
      fenshu.new = "优秀"
    } else if (x > 80) {
      fenshu.new = "良好"
    } else if (x > 70) {
      fenshu.new = "中等"
    } else if (x > 60) {
      fenshu.new = "及格"
    } else {
      fenshu.new = "不及格"
    }
    return(fenshu.new)
  } else {
    fenshu.df <- data.frame(dengji = rep(NA, length(x)))  #先生成一个数据框，存放等级，也可以生成向量再存储数据框
    for (i in seq_along(x)) {
      #按照顺序进行索引
      if (x[i] > 90) {
        #通过[]来索引
        fenshu.new = "优秀"
      } else if (x[i] > 80) {
        fenshu.new = "良好"
      } else if (x[i] > 70) {
        fenshu.new = "中等"
      } else if (x[i] > 60) {
        fenshu.new = "及格"
      } else {
        fenshu.new = "不及格"
      }
      fenshu.df[i, ] <- fenshu.new   # 将计算得到的等级存储在生成的数据框中
    }
    return(fenshu.df)               #返回数据框
  }
}
