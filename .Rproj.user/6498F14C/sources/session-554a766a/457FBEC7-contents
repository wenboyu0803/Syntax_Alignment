```{r 通过if来控制自定义函数2}
mytrans <- function(x) {
  if (!is.matrix(x)) {
    #判断是不是矩阵
    warning("argument is not a matrix.")
    return(NA)
  } else{
    y <- matrix(nrow = ncol(x), ncol = nrow(x))    #建立一个空矩阵
    for (i in 1:nrow(x)) {
      #遍历每一个元素
      for (j in 1:ncol(x)) {
        y[j, i] <- x[i, j]                      #转置存储
      }
    }
    return(y)
  }
}
r <- c(1,3)                               #测试
mytrans(r)
ma <- matrix(c(1:8), nrow = 4)
ma
mytrans(ma)
