```{r 自定义函数的多个返回值}
meanstd <- function(x){
  mu = mean(x)
  std = sqrt(sum((x - mu)^2)/(length(x) - 1))
  result <- list(mu = mu, std = std)
  #如果不使用list形式，先出来的结果，会被覆盖
  #return(std); return(mu)
  return(result)
}
yy <- c(1,2,3)
meanstd(yy)
