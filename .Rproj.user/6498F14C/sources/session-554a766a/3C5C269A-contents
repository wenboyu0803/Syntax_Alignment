#试着模拟500次，看看结果齐性不齐性有影响吗？
qixing <- function(m, n) {
  #自定义一个函数，有两个变量，m和n
  ScoreA <- rnorm(40, 10, m)
  ScoreB <- rnorm(40, 10, n) #分别从正态分布抽取标准差是mn的两列数据
  Score <- c(ScoreA, ScoreB)
  df.F <- data.frame(id = 1:80, group = c(rep("A", 40), rep("B", 40)), Score)
  #合并数据框
  aov.res <- afex::aov_ez(
    data = df.F,
    dv = "Score",
    between = "group",
    type = 3,
    id = "id"
  )
  aov.p <- aov.res$anova_table$`Pr(>F)` %>% round(7)
  lev <- car::leveneTest(data = df.F, Score ~ group) #方差齐性检验
  lev.p <- lev$`Pr(>F)`[1] %>% round(7)
  df.com <- cbind(aov.p, lev.p) %>% as.data.frame()#将生成的两个p值合并数据框
  return(df.com)
}

