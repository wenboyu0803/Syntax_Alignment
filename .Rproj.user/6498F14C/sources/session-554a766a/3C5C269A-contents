g.em1 <- emmeans(anova.1.b, ~ Group, contr = "pairwise")

#第二种写法（bruceR包）
g.em2 <- bruceR::EMMEANS(model = anova.1.b,
                         effect = "Group",
                         contrast = "pairwise")

g.em3 <- bruceR::EMMEANS(
  model = anova.1.b,
  effect = "Group",
  contrast = "pairwise",
  p.adjust = "none"
)
```

