```{r}
pipei <- rio::import("./data/Result0915.xlsx", which = "Sheet1")
set.seed(123)
n = 3000
result <- data.frame(
  ID = integer(n),
  viq.p = numeric(n),
  viqdiffe = numeric(n),
  tiq.p = numeric(n),
  totdiffe = numeric(n),
  age.p = numeric(n),
  agediffe = numeric(n),
  stringsAsFactors = FALSE
)
sam_num <- list()
TD <- pipei |> dplyr::filter(Group == "TD" & VIQ < 140)
AS <- pipei |> dplyr::filter(Group != "TD" & VIQ >= 90)
for (i in 1:n) {
  sam <- sample(nrow(TD), nrow(AS), replace = FALSE)
  sam_num[[i]] <- sam
  sub_TD <- TD[sam, ]
  viqmatch <- t.test(sub_TD$VIQ, AS$VIQ)
  viqdiffe <- mean(sub_TD$VIQ) - mean(AS$VIQ)
  totmatch <- t.test(sub_TD$TIQ, AS$TIQ)
  totdiffe <- mean(sub_TD$TIQ) - mean(AS$TIQ)
  agematch <- t.test(sub_TD$Age, AS$Age)
  agediffe <- mean(sub_TD$Age) - mean(AS$Age)
  result[i, ] <- c(
    i,
    viqmatch$p.value,
    viqdiffe,
    totmatch$p.value,
    totdiffe,
    agematch$p.value,
    agediffe
  )
}

result_new <- result |> arrange(across(c(viq.p, tiq.p, age.p), desc))
filtered_result <- result_new[result_new$viq.p > 0.05 & result_new$tiq.p > 0.05 & result_new$age.p > 0.05, ]

dir.create("pipei")
for (m in filtered_result$ID) {
  TD_new <- TD[unlist(sam_num[m]), ]
  name <- paste0("./pipei/", paste0(m, ".xlsx"))
  write_xlsx(TD_new, name)
}
write_xlsx(AS, "./pipei/ASD.xlsx")
```

