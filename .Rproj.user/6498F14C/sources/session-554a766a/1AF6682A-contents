2. 云雨图的本质
（1）小提琴图表示云彩（分布）
（2）散点图：对应被试在每个水平上的得分或者成绩，例如30个同学在心理语言学实验设计课程上的成绩
（3）箱图（可以省略）
（4）连线（以被试为单位），反映了被试在几个水平上的变化，例如，学于文勃课程前的数据分析水平和学习课程之后的水平
```{r 载入数据}
wd.1 <- import("./data/wd.1.csv") #读入数据
wd.2 <- wd.1 %>%
  group_by(age, subid)%>% #按照年龄和被试编号整理数据
  summarise(M = round(mean(pred.tran),3))%>% #整理因变量
  as.data.frame()

fig.age <- 
  ggplot(wd.2,aes(x= age,y = M, fill=age))+ 
  geom_half_violin(aes(color = age), position = position_nudge(x = 0.25),
                   side = "r", width=2)+ #小提琴在右侧
  geom_jitter(aes(fill = age), #填充映射不同的年龄
              shape = 21, #形状
              size = 2, #大小
              width = 0.07,
              color = 'black')+ #外圈的颜色
  scale_color_npg()+ #color的颜色
  scale_fill_npg()+ #填充的颜色
  theme_bw()+ #使用主题
  labs(x = "情绪类别",  
       y = "四种情绪正确可能性") +
  theme(axis.text.y = element_text(color = 'black',size=15), #设置坐标轴的字体
        axis.text.x = element_text(color = 'black',size=15),
        axis.title.x = element_text(color = 'black',size=17),
        axis.title.y = element_text(color = 'black',size=17),
        legend.position = "none")
fig.age
```


