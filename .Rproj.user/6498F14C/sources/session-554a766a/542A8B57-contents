```{r 点图和线图}
#p1:
ggplot(data = mpg, #data可以不写，但是数据要写
       mapping = aes(x = displ, y = hwy, color = drv))+ #映射一定要在aes里面
  geom_point() #括号不能省略，指的是上面的映射传输到下面来

#P2
ggplot(data = mpg, #data可以不写，但是数据要写
       mapping = aes(x = displ, y = hwy, color = drv))+ #映射一定要在aes里面
  geom_point(color = "darkblue")

#P3
ggplot(data = mpg, #data可以不写，但是数据要写
       mapping = aes(x = displ, y = hwy, color = drv))+ #映射一定要在aes里面
  geom_point()+ 
  geom_smooth()

#为什么p4和p5不一样?
#P4
ggplot(data = mpg, 
       mapping = aes(x = displ, y = hwy, color = drv))+ 
  geom_point()+ 
  geom_smooth()

#P5
ggplot(data = mpg, 
       mapping = aes(x = displ, y = hwy))+ 
  geom_point(mapping = aes(shape = drv, color = drv))+ 
  geom_smooth(mapping = aes(color = drv))
```


2. 分类数据指定颜色
虽然建立了颜色和变量的映射关系，但是每个水平的颜色是R语言自己选定，如果想设置自己喜欢的颜色怎么办？
```{r}
ggplot(data = mpg,
  #data可以不写，但是数据要写
  mapping = aes(x = displ, y = hwy, color = as.factor(drv))) + #映射一定要在aes里面
  geom_point() +
  scale_color_manual(values = c(f = "#f46f20",
                                r = "#156077",
                                `4` = "#9b3a74"))
