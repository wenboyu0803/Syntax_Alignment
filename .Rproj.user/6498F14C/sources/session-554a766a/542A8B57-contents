```{r 柱状图+errorbar}
wyx.d2 <- wyx.d %>%
  group_by(subid, age, Qingxu) %>%
  dplyr::summarise(value = mean(pred.tran))%>%
  dplyr::mutate(age = factor(age, levels = c("5 岁", "6 岁", "7 岁", 
                                             "8 岁", "9 岁", "10 岁", 
                                             "11 岁", "12 岁")))%>%
  group_by(age, Qingxu)%>%
  dplyr::summarise(mean.value = mean(value),
                   N = n(),
                   se = sd(value) / sqrt(N))%>%
  mutate(se = round(se, 3),
         yMIN = mean.value - 1.96 * se,
         yMAX = mean.value + 1.96 * se)%>%
  ungroup()%>%
  as.data.frame()


wyx.fig3 <- ggplot(data = wyx.d2, 
                   aes(x = age, #自变量
                       y = mean.value, #因变量
                       color = Qingxu,
                       fill = Qingxu))+
  geom_bar(stat = "identity", #不需要做数据转换
           position = position_dodge(width = 0.5) #如果不写会做成堆叠
           )+
  geom_errorbar(aes(ymin = yMIN,  #ymin = 下限
                    ymax = yMAX),  # ymax = 上限，误差bar一定是在映射里面
                position = position_dodge(width = 0.5), 
                linewidth = 0.6, #误差棒的线粗细
                width = 0.6) #误差棒的宽度
