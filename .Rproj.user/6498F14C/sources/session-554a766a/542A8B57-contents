```{r 复合图形}
data1 <- dplyr::select(mpg, model, hwy, cty) #筛选出有用的数据
unique(data1$model)
data2 <- data1 %>%
  dplyr::mutate(model1 = case_when(grepl("4wd", model) ~ "4WD",
                                   grepl("2wd", model) ~ "2WD",
                                   TRUE ~ "M"))
unique(data2$model1)

#先画箱图
fig.41 <- ggplot() +
  geom_boxplot(data = data2, 
               aes(x = as.factor(cty), y = hwy, 
                   color = model1, fill = model1),
               position = position_dodge(width = 0.6))

fig.41

#线图需要整理数据
data21 <- data2 %>%
  group_by(model1, cty)%>%
  summarise(hwy = round(mean(hwy), 3))

fig.42 <- fig.41 +
  geom_line(data = data21,
            mapping = aes(x = as.factor(cty), 
                          y = hwy, group = model1, color = model1))+
  geom_point(data = data21, 
             mapping = aes(x = as.factor(cty), 
                           y = hwy, group = model1, color = model1, shape = model1))+
  theme_light()

