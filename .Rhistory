df01$Syntax_production <- factor(df01$Syntax_production, levels = c("be", "ba", "zh"))
model_formulas <- list(
p1 = Rating.mean ~ 1 + Group * 词类 * Syntax_production + (1| Child_name) + (1 | Trials),
p2 = Rating.mean ~ 1 + Group * 词类 + Syntax_production + (1| Child_name) + (1 | Trials),
p3 = Rating.mean ~ 1 + Group + 词类 * Syntax_production + (1| Child_name) + (1 | Trials),
p4 = Rating.mean ~ 1 + Group + 词类 + Syntax_production + (1| Child_name) + (1 | Trials),
p5 = Rating.mean ~ 1 + Group * 词类 * Syntax_production + (1| Child_name),
