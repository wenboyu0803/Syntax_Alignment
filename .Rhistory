# 定义 logistic 转换函数
inv_logit <- function(x) {
1 / (1 + exp(-x))
}
# 从模型输出中提取系数点估计（中位数）
coefs <- c(
Intercept = -20.83,
Syntax_prime = 18.11,
GroupASD = 14.16,
WordClass = 0.29,      # 词类结果动机
PPVTZ = 1.04,
Interaction = -12.64   # Syntax_prime:GroupASD
)
# 定义预测函数
predict_prob <- function(Syntax_prime, Group_ASD, WordClass_value, PPVTZ_value) {
logit_p <- coefs["Intercept"] +
coefs["Syntax_prime"] * Syntax_prime +
coefs["GroupASD"] * Group_ASD +
coefs["WordClass"] * WordClass_value +
coefs["PPVTZ"] * PPVTZ_value +
coefs["Interaction"] * Syntax_prime * Group_ASD
return(inv_logit(logit_p))
}
# 设置预测条件
# 注意：Group_ASD = 0 表示 TD 儿童，= 1 表示 ASD 儿童
# 假设词类和PPVTZ取均值或0（根据你的数据情况调整）
# 情况A：词类和PPVTZ都取0（作为参照）
WordClass_ref <- 0
PPVTZ_ref <- 0
# 计算四种条件的概率
results <- data.frame(
Group = c("TD", "TD", "ASD", "ASD"),
Condition = c("Baseline", "BE", "Baseline", "BE"),
Syntax_prime = c(0, 1, 0, 1),
Group_ASD = c(0, 0, 1, 1),
Probability = c(
predict_prob(0, 0, WordClass_ref, PPVTZ_ref),  # TD Baseline
predict_prob(1, 0, WordClass_ref, PPVTZ_ref),  # TD BE
predict_prob(0, 1, WordClass_ref, PPVTZ_ref),  # ASD Baseline
predict_prob(1, 1, WordClass_ref, PPVTZ_ref)   # ASD BE
)
)
# 打印结果
print(results)
# 如果需要更清晰的输出
cat("\n========== 预测概率（点估计）==========\n")
cat(sprintf("TD儿童 - 句法基线条件: %.3f (%.1f%%)\n",
results$Probability[1], results$Probability[1]*100))
cat(sprintf("TD儿童 - BE句法条件: %.3f (%.1f%%)\n",
results$Probability[2], results$Probability[2]*100))
cat(sprintf("ASD儿童 - 句法基线条件: %.3f (%.1f%%)\n",
results$Probability[3], results$Probability[3]*100))
cat(sprintf("ASD儿童 - BE句法条件: %.3f (%.1f%%)\n",
results$Probability[4], results$Probability[4]*100))
# 定义 logistic 转换函数
inv_logit <- function(x) {
1 / (1 + exp(-x))
}
# 系数
coefs <- c(
Intercept = -20.83,
Syntax_prime = 18.11,
GroupASD = 14.16,
WordClass_motivation = 0.29,  # "结果动机"相对于参照水平的增加
PPVTZ = 1.04,
Interaction = -12.64
)
# ========== 方案1：预测"结果动机"这个词类 ==========
cat("\n========== 预测\"结果动机\"词类 ==========\n")
# PPVTZ的处理：如果已标准化，用0代表平均水平；否则用总体或分组均值
# 这里假设PPVTZ已标准化到总体均值为0
PPVTZ_value <- 0
# TD儿童
prob_TD_baseline_motivation <- inv_logit(
coefs["Intercept"] +
coefs["WordClass_motivation"] * 1 +  # 词类=结果动机
coefs["PPVTZ"] * PPVTZ_value
)
prob_TD_BE_motivation <- inv_logit(
coefs["Intercept"] +
coefs["Syntax_prime"] * 1 +
coefs["WordClass_motivation"] * 1 +
coefs["PPVTZ"] * PPVTZ_value
)
# ASD儿童
prob_ASD_baseline_motivation <- inv_logit(
coefs["Intercept"] +
coefs["GroupASD"] * 1 +
coefs["WordClass_motivation"] * 1 +
coefs["PPVTZ"] * PPVTZ_value
)
prob_ASD_BE_motivation <- inv_logit(
coefs["Intercept"] +
coefs["Syntax_prime"] * 1 +
coefs["GroupASD"] * 1 +
coefs["WordClass_motivation"] * 1 +
coefs["PPVTZ"] * PPVTZ_value +
coefs["Interaction"] * 1 * 1
)
results <- data.frame(
组别 = c("TD", "TD", "ASD", "ASD"),
句法条件 = c("基线", "BE", "基线", "BE"),
词类 = "结果动机",
概率 = c(prob_TD_baseline_motivation, prob_TD_BE_motivation,
prob_ASD_baseline_motivation, prob_ASD_BE_motivation)
)
print(results)
