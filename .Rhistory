p16 = Rating.mean ~ 1 + Group + 词类 + Syntax_production)
p_objects <- list()
p_summaries <- list ()
for (model_name in names(model_formulas)) {
formula <- model_formulas[[model_name]]
model <- brm(
formula = formula,
data = df01 ,
init = 0,
chains = 4,
warmup = 1000,
iter = 5000,
thin = 1,
cores = 4)
p_objects[[model_name]] <- model
p_summaries[[model_name]] <- summary(model)
}
