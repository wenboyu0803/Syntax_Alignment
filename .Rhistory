# 模型系数
beta_0 <- 0.62      # Intercept
beta_1 <- 0.75      # 词类结果动补
beta_2 <- -1.89     # 句法结构be
beta_3 <- 0.21      # 组别ASD
beta_4 <- -0.58     # 交互项
# 定义 logit 转概率的函数
inv_logit <- function(x) {
exp(x) / (1 + exp(x))
}
# 创建所有条件的组合
conditions <- expand.grid(
组别 = c("TD", "ASD"),
词类 = c("趋向动补", "结果动补"),
句法结构 = c("把字句", "be")
)
# 计算每个条件的 logit 和概率
conditions$logit <- NA
conditions$概率 <- NA
for (i in 1:nrow(conditions)) {
# 判断是否使用各系数
use_beta1 <- ifelse(conditions$词类[i] == "结果动补", 1, 0)
use_beta2 <- ifelse(conditions$句法结构[i] == "be", 1, 0)
use_beta3 <- ifelse(conditions$组别[i] == "ASD", 1, 0)
use_beta4 <- ifelse(conditions$词类[i] == "结果动补" &
conditions$句法结构[i] == "be", 1, 0)
# 计算 logit
conditions$logit[i] <- beta_0 +
beta_1 * use_beta1 +
beta_2 * use_beta2 +
beta_3 * use_beta3 +
beta_4 * use_beta4
# 转换为概率
conditions$概率[i] <- inv_logit(conditions$logit[i])
}
# 查看结果
print(conditions)
