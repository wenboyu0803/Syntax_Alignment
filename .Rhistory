df02 <- df %>%
dplyr::filter(Sen_ACC == 1) %>%
merge(basic, by = "Child_name") %>%
dplyr::mutate(Group = Group.x) %>%
dplyr::select(-Group.x, -Group.y, -contains(".x"), -contains(".y"), -Task_Data, -Birth_data) %>%
dplyr::select(Child_name, Sex, Age, Group, everything()) %>%
dplyr::mutate(词类 = ifelse(Words_prime %in% quxiang, "趋向动补", "结果动补"),
词类 = factor(词类, levels = c("趋向动补", "结果动补")),
Syntax_production = ifelse(is.na(Syntax_production), "错误",
as.character(Syntax_production)),
Group = factor(Group, levels = c("TDC", "ASD")),
Syntax_prime = factor(Syntax_prime, levels = c("zh", "ba", "be")))
df
ASD <- rio::import("./data/ASD.xlsx")
TDC <- rio::import("./data/TDC.xlsx")
b1 <- rio::import("./data/Result1002.xlsx", which = "Block1")
b2 <- rio::import("./data/Result1002.xlsx", which = "Block2")
b3 <- rio::import("./data/Result1002.xlsx", which = "Block3")
basic <- rio::import("./data/Result1002.xlsx", which = "basic") %>%
filter(Child_name %in% c(ASD$Child_name, TDC$Child_name)) %>%
mutate(AGE = scale(Age)[, 1],
PPVTZ = scale(PPVT)[, 1])
df <- bind_rows(b1, b2, b3)
df
df02 <- df %>%
dplyr::filter(Sen_ACC == 1) %>%
merge(basic, by = "Child_name") %>%
dplyr::mutate(Group = Group.x) %>%
dplyr::select(-Group.x, -Group.y, -contains(".x"), -contains(".y"), -Task_Data, -Birth_data) %>%
dplyr::select(Child_name, Sex, Age, Group, everything()) %>%
dplyr::mutate(词类 = ifelse(Words_prime %in% quxiang, "趋向动补", "结果动补"),
词类 = factor(词类, levels = c("趋向动补", "结果动补")),
Syntax_production = ifelse(is.na(Syntax_production), "错误",
as.character(Syntax_production)),
Group = factor(Group, levels = c("TDC", "ASD")),
Syntax_prime = factor(Syntax_prime, levels = c("zh", "ba", "be")))
df02 <- merge(df02, pingfen, by = "Rate_ID")
df02
dfbe3 <- df02 |>
dplyr::select(Child_name, Group, Syntax_prime, Syntax_production, PPVTZ, 词类, Trials) |>
dplyr::filter(Syntax_prime == "be", Syntax_production != "错误") |>
dplyr::mutate(Syntax_production = factor(Syntax_production, levels = c("be", "ba", "zh")))
dfbe3
dfbe3 <- df02 |>
dplyr::select(Child_name, Group, Syntax_prime, Syntax_production, PPVTZ, 词类, Trials) |>
dplyr::filter(Syntax_prime == "be", Syntax_production != "错误") |>
dplyr::mutate(Syntax_production = factor(Syntax_production, levels = c("be", "ba", "zh")))
model_formulas <- list(
mul.be1 = Syntax_production ~ 1 + Group + PPVTZ + (1| Child_name) + (1 | Trials),
mul.be2 = Syntax_production ~ 1 + Group + PPVTZ + (1| Trials),
mul.be3 = Syntax_production ~ 1 + Group + PPVTZ + (1| Child_name),
mul.be4 = Syntax_production ~ 1 + Group + PPVTZ,
mul.be5 = Syntax_production ~ 1 + Group + (1| Trials) +(1| Child_name),
mul.be6 = Syntax_production ~ 1 + Group + (1| Trials),
mul.be7 = Syntax_production ~ 1 + Group + (1| Child_name),
mul.be8 = Syntax_production ~ 1 + Group,
mul.be9 = Syntax_production ~ 1 + PPVTZ + (1| Child_name) + (1 | Trials),
mul.be10 = Syntax_production ~ 1 + PPVTZ + (1| Child_name),
mul.be11 = Syntax_production ~ 1 + PPVTZ + (1| Trials),
mul.be12 = Syntax_production ~ 1 + PPVTZ,
mul.be13 = Syntax_production ~ 1)
BE_objects <- list()
BE_summaries <- list ()
for (model_name in names(model_formulas)) {
formula <- model_formulas[[model_name]]
model <- brm(
formula = formula,
data = dfbe3,
init = 0,
family = categorical(link = "logit"),
chains = 4,
warmup = 1000,
iter = 5000,
thin = 1,
cores = 4)
BE_objects[[model_name]] <- model
BE_summaries[[model_name]] <- summary(model)
}
loo_be <- list()
for (model_name in names(BE_objects)) {
loo_be[[model_name]] <- LOO(BE_objects[[model_name]])
}
be.compare <- brms::LOO(
BE_objects$mul.be1,
BE_objects$mul.be2,
BE_objects$mul.be3,
BE_objects$mul.be4,
BE_objects$mul.be5,
BE_objects$mul.be6,
BE_objects$mul.be7,
BE_objects$mul.be8,
BE_objects$mul.be9,
BE_objects$mul.be10,
BE_objects$mul.be11,
BE_objects$mul.be12,
BE_objects$mul.be13
)
#bayestestR::hdi(quxiang_objects$mul.qx13)
be.compare
BE_summaries$mul.be9
BE_summaries$mul.be5
BE_summaries$mul.be9
bayestestR::hdi(BE_objects$mul.be9)
bayestestR::hdi(BE_objects$mul.be5)
bayestestR::hdi(BE_objects$mul.be13)
BE_summaries$mul.be13
df02
